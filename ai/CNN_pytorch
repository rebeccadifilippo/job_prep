# super_simple_cnn_commented.py
# VERY simple CNN with detailed comments to understand each step

import torch
import torch.nn as nn  # PyTorch neural network modules
import torch.nn.functional as F  # PyTorch functional API (for activations like ReLU)

# ===== 1. Define a simple CNN model =====
class SimpleCNN(nn.Module):
    def __init__(self):
        super().__init__()  # initialize the parent nn.Module

        # ----- Convolutional layer -----
        # in_channels=3: input has 3 channels (RGB image)
        # out_channels=8: this layer will learn 8 filters → produces 8 feature maps
        # kernel_size=3: each filter is 3x3
        # padding=1: keeps the output width/height same as input (32x32)
        self.conv = nn.Conv2d(
            in_channels=3,
            out_channels=8,
            kernel_size=3,
            padding=1
        )

        # ----- Pooling layer -----
        # MaxPool2d reduces spatial dimensions (height/width) by taking the max in 2x2 blocks
        # stride=2 → moves the window 2 pixels each step
        self.pool = nn.MaxPool2d(2, 2)

        # ----- Fully connected layer -----
        # Input features = 8 filters * 16 height * 16 width = 2048
        # Output features = 10 → number of classes (for CIFAR-10)
        self.fc = nn.Linear(8 * 16 * 16, 10)

    # ===== Forward pass =====
    def forward(self, x):
        # Input x shape: (batch_size, 3, 32, 32)

        # ---- Step 1: Convolution ----
        x = self.conv(x)
        # Each of the 8 filters slides across all 3 channels
        # Output shape: (batch_size, 8, 32, 32)
        # Each of the 8 output channels is a feature map learned from input

        # ---- Step 2: ReLU activation ----
        x = F.relu(x)
        # Sets negative values to 0
        # Adds non-linearity so the network can learn complex patterns
        # Output shape remains the same: (batch_size, 8, 32, 32)

        # ---- Step 3: Max Pooling ----
        x = self.pool(x)
        # Reduces spatial dimensions by half: (32x32 → 16x16)
        # Output shape: (batch_size, 8, 16, 16)

        # ---- Step 4: Flatten ----
        x = x.view(-1, 8 * 16 * 16)
        # Converts 3D feature maps into 1D vector for fully connected layer
        # -1 automatically adjusts for batch size
        # Output shape: (batch_size, 2048)

        # ---- Step 5: Fully connected layer ----
        x = self.fc(x)
        # Produces 10 scores per image (one per class)
        # Output shape: (batch_size, 10)

        return x

# ===== 2. Test the model =====
model = SimpleCNN()  # create an instance of the model

# Create a fake batch of images for testing
# torch.randn generates random numbers from a normal distribution
# Shape: (1 image, 3 channels, 32x32 pixels)
x = torch.randn(1, 3, 32, 32)

# Run forward pass
output = model(x)

# Print output shape
# Expected: (1, 10) → 1 image, 10 class scores
print("Output shape:", output.shape)